<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_patients_form" model="ir.ui.view">
        <field name="name">patients.form</field>
        <field name="model">patients</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="waiting,in_review,treated,follow_up"/>
                </header>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Patient Name"/></h1>
                    </div>
                    <group string="Basic Information">
                        <group>
                            <field name="health_seeker_id"/>
                            <field name="age"/>
                            <field name="gender"/>
                            <field name="nic"/>
                            <field name="phone"/>
                            <field name="email"/>
                        </group>
                        <group>
                            <field name="blood_group"/>
                            <field name="dependent"/>
                            <field name="project_id"/>
                            <field name="treatment_date"/>
                            <field name="follow_up_date"/>
                            <field name="assigned_doctor"/>
                            <field name="assigned_nurse"/>
                        </group>
                    </group>
                    <group string="Contact &amp; Emergency">
                        <group>
                            <field name="address"/>
                        </group>
                        <group>
                            <field name="emergency_contact_name"/>
                            <field name="emergency_contact"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="General Info">
                            <group>
                                <group>
                                    <field name="assigned_nurse"/>
                                    <field name="consultation_room"/>
                                    <field name="diseases"/>
                                    <field name="responsible_jr_doctor"/>
                                    <field name="urgency_level"/>
                                    <field name="purpose"/>
                                    <field name="is_video_call"/>
                                    <field name="outside_appointment"/>
                                </group>
                            </group>
                            <group string="History">
                                <field name="chief_complaints"
                                    placeholder="Chief Complaints..."/>
                                <field name="history_of_present_illness"
                                    placeholder="History of Present Illness..."/>
                                <field name="past_history"
                                    placeholder="Past History..."/>
                                <field name="general_notes"
                                    placeholder="Notes..."/>
                            </group>
                        </page>
                        <page string="Vital Signs &amp; Symptoms">
                            <group string="Vitals">
                                <group>
                                    <field name="hr_temperature"/>
                                    <field name="weight"/>
                                    <field name="height"/>
                                    <field name="bmi"/>
                                    <field name="bmi_state"/>
                                </group>
                                <group>
                                    <field name="rr"/>
                                    <field name="systolic_bp"/>
                                    <field name="diastolic_bp"/>
                                    <field name="spo2"/>
                                    <field name="rbs"/>
                                </group>
                            </group>
                            <group string="Reports">
                                <field name="pain_level"
                                    placeholder="Pain Level..."/>
                                <field name="laboratory"
                                    placeholder="Laboratory Report Notes..."/>
                                <field name="lab_image" widget="image"
                                    string="Lab Report Image"
                                    options="{'size': [400, 300]}"/>
                                <field name="lab_pdf" widget="binary"
                                    string="Lab Report PDF"
                                    filename="lab_pdf_filename"/>
                                <field name="lab_pdf_filename" invisible="1"/>
                                <field name="radiological"
                                    placeholder="Radiological Report..."/>
                                <field name="vital_notes"
                                    placeholder="Notes..."/>
                            </group>
                        </page>
                        <page string="Clinical Assessment">
                            <group string="Body Systems">
                                <group>
                                    <field name="head_neck"
                                        placeholder="Head &amp; Neck findings..."/>
                                    <field name="ent"
                                        placeholder="ENT findings..."/>
                                    <field name="eye"
                                        placeholder="Eye findings..."/>
                                    <field name="chest_heart"
                                        placeholder="Chest &amp; Heart findings..."/>
                                    <field name="git"
                                        placeholder="GIT findings..."/>
                                    <field name="surgery"
                                        placeholder="Surgery notes..."/>
                                </group>
                                <group>
                                    <field name="urinary_gynecology"
                                        placeholder="Urinary &amp; Gynecology..."/>
                                    <field name="orthopedic_neuro"
                                        placeholder="Orthopedic &amp; Neuro..."/>
                                    <field name="mouth"
                                        placeholder="Mouth findings..."/>
                                    <field name="skin"
                                        placeholder="Skin findings..."/>
                                    <field name="miscellaneous"
                                        placeholder="Miscellaneous..."/>
                                    <field name="mental_status"
                                        placeholder="Mental Status..."/>
                                </group>
                            </group>
                        </page>
                        <page string="Diagnosis &amp; Treatment">
                            <group>
                                <field name="sickness"
                                    placeholder="Sickness / Symptoms..."/>
                                <field name="diagnosis"
                                    placeholder="Doctor's diagnosis..."/>
                                <field name="prescription"
                                    placeholder="Medicines and prescriptions..."/>
                                <field name="notes"
                                    placeholder="Additional notes..."/>
                            </group>
                            <group string="Primary Diagnosis">
                                <field name="primary_icd10_id"/>
                                <field name="primary_icd10_code"/>
                            </group>
                            <group string="Diagnoses (ICD-10)">
                                <field name="diagnosis_line_ids" nolabel="1">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="icd10_id"/>
                                        <field name="icd10_code"/>
                                        <field name="description"/>
                                        <field name="diagnosis_type"/>
                                        <field name="notes"/>
                                    </list>
                                </field>
                            </group>
                            <group string="Procedures (CPT)">
                                <field name="procedure_line_ids" nolabel="1">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="cpt_id"/>
                                        <field name="cpt_code"/>
                                        <field name="description"/>
                                        <field name="notes"/>
                                    </list>
                                </field>
                            </group>
                            <group string="Prescriptions (RxNorm)">
                                <field name="prescription_line_ids" nolabel="1">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="drug_id"/>
                                        <field name="drug_name"/>
                                        <field name="snomed_id"/>
                                        <field name="dosage"/>
                                        <field name="frequency"/>
                                        <field name="duration"/>
                                        <field name="route"/>
                                        <field name="quantity"/>
                                        <field name="instructions"/>
                                    </list>
                                </field>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_patients_list" model="ir.ui.view">
        <field name="name">patients.list</field>
        <field name="model">patients</field>
        <field name="arch" type="xml">
            <list>
                <field name="health_seeker_id"/>
                <field name="name"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="phone"/>
                <field name="nic"/>
                <field name="status"/>
                <field name="assigned_doctor"/>
                <field name="urgency_level"/>
                <field name="project_id"/>
                <field name="treatment_date"/>
            </list>
        </field>
    </record>

    <record id="action_patients" model="ir.actions.act_window">
        <field name="name">All Patients</field>
        <field name="res_model">patients</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>