<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="view_thought_of_the_day_list" model="ir.ui.view">
        <field name="name">thought.of.the.day.list</field>
        <field name="model">thought.of.the.day</field>
        <field name="arch" type="xml">
            <list string="Thought of the Days">
                <field name="date"/>
                <field name="name"/>
                <field name="is_published"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_thought_of_the_day_form" model="ir.ui.view">
        <field name="name">thought.of.the.day.form</field>
        <field name="model">thought.of.the.day</field>
        <field name="arch" type="xml">
            <form string="Thought of the Day">
                <header>
                    <button name="action_publish" type="object"
                            string="Publish" class="btn-primary"
                            invisible="is_published"/>
                    <button name="action_unpublish" type="object"
                            string="Unpublish" class="btn-secondary"
                            invisible="not is_published"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Wisdom Title..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="is_published"/>
                            <field name="day_number"/>
                        </group>
                        <group>
                            <field name="image" widget="image" class="oe_avatar"/>
                            <field name="video" filename="video_filename"/>
                            <field name="video_url"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Content" name="content">
                            <field name="content" widget="html" placeholder="Write your wisdom content here..."/>
                        </page>
                        <page string="Summary" name="summary">
                            <field name="summary" placeholder="Brief summary..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_thought_of_the_day_search" model="ir.ui.view">
        <field name="name">thought.of.the.day.search</field>
        <field name="model">thought.of.the.day</field>
        <field name="arch" type="xml">
            <search string="Search Thoughts">
                <field name="name"/>
                <filter name="published" string="Published"
                        domain="[('is_published','=',True)]"/>
                <filter name="unpublished" string="Unpublished"
                        domain="[('is_published','=',False)]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_thought_of_the_day" model="ir.actions.act_window">
        <field name="name">Thought of the Days</field>
        <field name="res_model">thought.of.the.day</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_thought_of_the_day_search"/>
    </record>

</odoo>