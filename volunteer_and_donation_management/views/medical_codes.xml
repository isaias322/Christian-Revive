<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════ -->
    <!-- ICD-10 VIEWS                                    -->
    <!-- ═══════════════════════════════════════════════ -->
    <record id="view_icd10_list" model="ir.ui.view">
        <field name="name">medical.icd10.list</field>
        <field name="model">medical.icd10</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="category"/>
                <field name="chapter"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="view_icd10_form" model="ir.ui.view">
        <field name="name">medical.icd10.form</field>
        <field name="model">medical.icd10</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="category"/>
                        </group>
                        <group>
                            <field name="chapter"/>
                            <field name="is_active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_icd10" model="ir.actions.act_window">
        <field name="name">ICD-10 Codes</field>
        <field name="res_model">medical.icd10</field>
        <field name="view_mode">list,form</field>
    </record>

