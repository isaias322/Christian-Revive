<odoo>
    <record id="view_onevoice_bible_study_form" model="ir.ui.view">
        <field name="name">onevoice.bible.study.form</field>
        <field name="model">onevoice.bible.study</field>
        <field name="arch" type="xml">
            <form string="OneVoice27 Bible Study">
                <header>
                    <button name="action_set_interested" type="object" string="Interested" class="btn-secondary"/>
                    <button name="action_set_in_progress" type="object" string="In Progress" class="btn-primary"/>
                    <button name="action_set_completed" type="object" string="Completed" class="btn-success"/>
                    <button name="action_mark_certificate_issued" type="object" string="Certificate Issued" class="btn-success" invisible="not certificate_eligible or certificate_issued"/>
                    <field name="state" widget="statusbar" statusbar_visible="interested,in_progress,completed"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Certificate Ready" bg_color="text-bg-success" invisible="not certificate_eligible or certificate_issued"/>
                    <widget name="web_ribbon" title="Certificate Issued" bg_color="text-bg-info" invisible="not certificate_issued"/>
                    <group>
                        <group>
                            <field name="contact_name"/>
                            <field name="phone"/>
                            <field name="location"/>
                        </group>
                        <group>
                            <field name="study_days"/>
                            <field name="partner_id"/>
                            <field name="create_date" readonly="1"/>
                        </group>
                    </group>
                    <group string="Study Progress">
                        <group>
                            <field name="completed_session_count"/>
                            <field name="total_session_count"/>
                            <field name="certificate_eligible" readonly="1"/>
                        </group>
                        <group>
                            <field name="certificate_issued"/>
                            <field name="certificate_issued_date" readonly="1"/>
                        </group>
                    </group>
                    <field name="completed_session_ids" invisible="1"/>
                    <separator string="Notes"/>
                    <field name="notes" placeholder="Add follow-up notes here..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_onevoice_bible_study_list" model="ir.ui.view">
        <field name="name">onevoice.bible.study.list</field>
        <field name="model">onevoice.bible.study</field>
        <field name="arch" type="xml">
            <list string="OneVoice27 Bible Studies">
                <field name="contact_name"/>
                <field name="phone"/>
                <field name="location"/>
                <field name="study_days"/>
                <field name="completed_session_count"/>
                <field name="total_session_count"/>
                <field name="certificate_eligible"/>
                <field name="certificate_issued"/>
                <field name="state"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="action_onevoice_bible_study" model="ir.actions.act_window">
        <field name="name">OneVoice27 Bible Studies</field>
        <field name="res_model">onevoice.bible.study</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
