<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="view_sabbath_school_list" model="ir.ui.view">
        <field name="name">sabbath.school.lesson.list</field>
        <field name="model">sabbath.school.lesson</field>
        <field name="arch" type="xml">
            <list string="Sabbath School Lessons">
                <field name="name"/>
                <field name="date"/>
                <field name="quarter"/>
                <field name="year"/>
                <field name="is_published"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_sabbath_school_form" model="ir.ui.view">
        <field name="name">sabbath.school.lesson.form</field>
        <field name="model">sabbath.school.lesson</field>
        <field name="arch" type="xml">
            <form string="Sabbath School Lesson">
                <header>
                    <button name="action_publish" type="object"
                            string="Publish" class="btn-primary"
                            invisible="is_published"/>
                    <button name="action_unpublish" type="object"
                            string="Unpublish" class="btn-secondary"
                            invisible="not is_published"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Lesson Title..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="quarter"/>
                            <field name="year"/>
                            <field name="is_published"/>
                        </group>
                        <group>
                            <field name="image" widget="image" class="oe_avatar"/>
                            <field name="pdf_file" filename="pdf_filename"/>
                            <field name="pdf_filename" invisible="1"/>
                            <field name="video_url"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Brief description..."/>
                        </page>
                        <page string="Content" name="content">
                            <field name="content" widget="html" placeholder="Full lesson content..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_sabbath_school_search" model="ir.ui.view">
        <field name="name">sabbath.school.lesson.search</field>
        <field name="model">sabbath.school.lesson</field>
        <field name="arch" type="xml">
            <search string="Search Lessons">
                <field name="name"/>
                <field name="quarter"/>
                <field name="year"/>
                <filter name="published" string="Published"
                        domain="[('is_published','=',True)]"/>
                <filter name="unpublished" string="Unpublished"
                        domain="[('is_published','=',False)]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_sabbath_school" model="ir.actions.act_window">
        <field name="name">Sabbath School Lessons</field>
        <field name="res_model">sabbath.school.lesson</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_sabbath_school_search"/>
    </record>

</odoo>