<odoo>
    <record id="view_prayer_request_form" model="ir.ui.view">
        <field name="name">prayer.request.form</field>
        <field name="model">prayer.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" clickable="1"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="subject"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="state"/>
                            <field name="pray_count"/>
                            <field name="is_published"/>
                        </group>
                    </group>
                    <separator string="Prayer Message"/>
                    <field name="message"/>
                    <separator string="Response (visible in app)"/>
                    <group>
                        <field name="response_by"/>
                        <field name="response_date"/>
                        <field name="prayed_by"/>
                    </group>
                    <field name="response" placeholder="Write your prayer response here... This will be visible to the requester in the app."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_prayer_request_list" model="ir.ui.view">
        <field name="name">prayer.request.list</field>
        <field name="model">prayer.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="subject"/>
                <field name="email"/>
                <field name="state"/>
                <field name="pray_count"/>
                <field name="response_by"/>
                <field name="is_published"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="action_prayer_request" model="ir.actions.act_window">
        <field name="name">Prayer Requests</field>
        <field name="res_model">prayer.request</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>