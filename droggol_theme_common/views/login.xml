<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="dr_web_login_force_form" inherit_id="web.login" name="Force visible website login form">
        <xpath expr="//owl-component[@name='web.user_switch']" position="replace"/>
        <xpath expr="//form[contains(@t-attf-class, 'oe_login_form')]" position="attributes">
            <attribute name="t-attf-class">oe_login_form</attribute>
        </xpath>
    </template>
</odoo>
