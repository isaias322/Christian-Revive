<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_donate_form" model="ir.ui.view">
        <field name="name">donate.form</field>
        <field name="model">donate</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Donation Name"/></h1>
                    </div>
                    <group>
                        <group string="Details">
                            <field name="description"/>
                            <field name="currency_symbol"/>
                            <field name="is_active"/>
                        </group>
                        <group string="Goal Tracking">
                            <field name="goal_amount"/>
                            <field name="raised_amount"/>
                            <field name="donation_count"/>
                        </group>
                    </group>
                    <group string="Gallery Images">
                        <field name="image" widget="image"/>
                        <field name="image_2" widget="image"/>
                        <field name="image_3" widget="image"/>
                    </group>
                    <group string="Project Document">
                        <field name="project_pdf" filename="project_pdf_filename"/>
                        <field name="project_pdf_filename" invisible="1"/>
                    </group>
                    <notebook>
                        <page string="Transactions">
                            <field name="transaction_ids">
                                <list>
                                    <field name="date"/>
                                    <field name="donor_name"/>
                                    <field name="amount"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_donate_list" model="ir.ui.view">
        <field name="name">donate.list</field>
        <field name="model">donate</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
                <field name="goal_amount"/>
                <field name="raised_amount"/>
                <field name="donation_count"/>
            </list>
        </field>
    </record>

    <record id="action_donate" model="ir.actions.act_window">
        <field name="name">Donations</field>
        <field name="res_model">donate</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>