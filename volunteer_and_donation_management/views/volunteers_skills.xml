<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- list View -->
    <record id="view_volunteer_skill_list" model="ir.ui.view">
        <field name="name">volunteer.skill.list</field>
        <field name="model">volunteer.skill</field>
        <field name="arch" type="xml">
            <list string="Volunteer Skills">
                <field name="name"/>
                <field name="code"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_volunteer_skill_form" model="ir.ui.view">
        <field name="name">volunteer.skill.form</field>
        <field name="model">volunteer.skill</field>
        <field name="arch" type="xml">
            <form string="Volunteer Skill">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="color" widget="color_picker"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_volunteer_skill" model="ir.actions.act_window">
        <field name="name">Volunteer Skills</field>
        <field name="res_model">volunteer.skill</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>