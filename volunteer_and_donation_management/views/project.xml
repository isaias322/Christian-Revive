<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_app_project_form" model="ir.ui.view">
        <field name="name">app.project.form</field>
        <field name="model">app.project</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="project_type"/>
                        <field name="is_active"/>
                    </group>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_app_project_list" model="ir.ui.view">
        <field name="name">app.project.list</field>
        <field name="model">app.project</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="project_type"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="action_app_projects" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">app.project</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>