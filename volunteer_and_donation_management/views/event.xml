<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_church_event_form" model="ir.ui.view">
        <field name="name">church.event.form</field>
        <field name="model">church.event</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Event Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="location"/>
                            <field name="category"/>
                            <field name="is_published"/>
                        </group>
                        <group>
                            <field name="video_url"/>
                            <field name="video" filename="name"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Content">
                            <field name="content"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_church_event_list" model="ir.ui.view">
        <field name="name">church.event.list</field>
        <field name="model">church.event</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="location"/>
                <field name="category"/>
                <field name="is_published"/>
            </list>
        </field>
    </record>

    <record id="action_church_events" model="ir.actions.act_window">
        <field name="name">Events</field>
        <field name="res_model">church.event</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>